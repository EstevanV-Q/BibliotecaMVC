@{
    ViewBag.Title = "Inicio";
}

<!-- HERO SECTION -->
<div class="hero">
    <h1><i class="fas fa-book-open" style="opacity:.8;"></i> Biblioteca Virtual MVC</h1>
    <p>Gestione su catálogo de libros de forma eficiente y profesional con un sistema diseñado en ASP.NET MVC.</p>
    <div class="hero-btns">
        <a href="@Url.Action("Registrar", "Libro")" class="btn btn-success">
            <i class="fas fa-plus-circle"></i> Registrar Libro
        </a>
        <a href="@Url.Action("Index", "Libro")" class="btn btn-outline-white">
            <i class="fas fa-search"></i> Consultar Catálogo
        </a>
    </div>
</div>

<!-- FEATURES GRID -->
<div class="features-grid">
    <div class="feature-card">
        <div class="feature-icon blue">
            <i class="fas fa-book"></i>
        </div>
        <h3>Gestión de Libros</h3>
        <p>Registre nuevos títulos indicando código, autor y fecha de publicación de forma rápida y sencilla.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon green">
            <i class="fas fa-shield-halved"></i>
        </div>
        <h3>Validación de Datos</h3>
        <p>El sistema utiliza <strong>DataAnnotations</strong> para asegurar que todos los datos ingresados sean correctos.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon purple">
            <i class="fas fa-layer-group"></i>
        </div>
        <h3>Patrón MVC</h3>
        <p>Arquitectura limpia con separación de <strong>Modelos</strong>, <strong>Vistas</strong> y <strong>Controladores</strong>.</p>
    </div>
</div>